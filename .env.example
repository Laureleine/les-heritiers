# Supabase — Frontend (clé anon, publique)
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_votre_cle_anon

# Supabase — Service Role (ADMIN — à garder secret !)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIs...

# Supabase — Base de données (connexion directe PostgreSQL)
SUPABASE_DB_URL=postgresql://postgres.votre-projet:motdepasse@aws-1-eu-west-3.pooler.supabase.com:6543/postgres

# Google OAuth — Drive API (release automatisée)
GOOGLE_CLIENT_ID="votre-client-id"
GOOGLE_CLIENT_SECRET="votre-client-secret"
GOOGLE_REFRESH_TOKEN="1//votre-refresh-token"
GOOGLE_FOLDER_ID="votre-folder-id"

# NotebookLM
NOTEBOOKLM_NOTEBOOK_ID=votre-notebook-id

# Cloudflare Turnstile (anti-bot pour l'inscription)
VITE_TURNSTILE_SITE_KEY=0x4AAAAAA...votre-turnstile-sitekey
VITE_APP_URL=https://heritiers.app
# SUPABASE_AUTH_CAPTCHA_SECRET=0x4AAAAAA...votre-turnstile-secret

# Tests E2E Playwright (compte de test dédié)
E2E_EMAIL=votre-compte-test@example.com
E2E_PASSWORD=votre-mot-de-passe-test
