> -- Name: delete_personal_fairy_asset(uuid); Type: FUNCTION; Schema: public; Owner: -
> --
> 
> CREATE FUNCTION public.delete_personal_fairy_asset(p_id uuid) RETURNS void
>     LANGUAGE plpgsql SECURITY DEFINER
>     SET search_path TO 'public'
>     AS $$
> DECLARE
>   v_existing fairy_assets%ROWTYPE;
>   v_count    integer;
> BEGIN
>   IF auth.uid() IS NULL THEN
>     RAISE EXCEPTION 'Non authentifié';
>   END IF;
> 
>   SELECT * INTO v_existing FROM fairy_assets WHERE id = p_id;
>   IF NOT FOUND THEN
>     RAISE EXCEPTION 'Carte introuvable';
>   END IF;
>   IF v_existing.creator_id IS DISTINCT FROM auth.uid() THEN
>     RAISE EXCEPTION 'Accès refusé';
>   END IF;
> 
>   -- Bloquer si un personnage possède cette carte (cherche l'id dans le JSONB atouts)
>   SELECT COUNT(*) INTO v_count
>   FROM characters
>   WHERE atouts @> jsonb_build_array(jsonb_build_object('id', p_id::text));
> 
>   IF v_count > 0 THEN
>     RAISE EXCEPTION 'Cette carte est en possession d''un ou plusieurs personnages';
>   END IF;
> 
>   -- Bloquer si une distribution active existe
>   SELECT COUNT(*) INTO v_count
>   FROM personal_card_grants
>   WHERE card_id = p_id AND status NOT IN ('archived', 'rejected');
> 
>   IF v_count > 0 THEN
>     RAISE EXCEPTION 'Cette carte a été distribuée à des joueurs';
>   END IF;
> 
>   DELETE FROM fairy_assets WHERE id = p_id;
> END;
> $$;
> 
> 
> --
